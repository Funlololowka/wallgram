{
  "name": "wallgram",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @wallgram/server\" \"npm run dev --workspace @wallgram/web\"",
    "dev:server": "npm run dev --workspace @wallgram/server",
    "dev:web": "npm run dev --workspace @wallgram/web",
    "build": "npm run build --workspace @wallgram/server && npm run build --workspace @wallgram/web"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}